generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  String        @id @default(uuid())
  name                String
  weeklyQuota         Int           @default(1000)
  weeklyUsage         Int           @default(0)
  usageResetAt        DateTime      @default(now())
  createdAt           DateTime      @default(now())
  website             String?
  contactPersonName   String?
  contactPersonTitle  String?
  contactPersonEmail  String?
  contactPersonPhone  String?

  crawlBatches    CrawlBatch[]
  tenantCompanies TenantCompany[]
  users           User[]
  emailTemplates  EmailTemplate[]
}

model User {
  id                     String   @id @default(uuid())
  email                  String   @unique
  passwordHash           String
  tenantId               String
  role                   UserRole @default(USER)
  monthlyDomainLimit     Int?
  emailVerified          Boolean  @default(false)
  emailVerificationToken String?  @unique
  createdAt              DateTime @default(now())

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  monthlyUsage UserMonthlyUsage[]
}

model UserMonthlyUsage {
  id          String   @id @default(uuid())
  userId      String
  month       String
  domainsUsed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

model Company {
  id            String    @id @default(uuid())
  domain        String    @unique
  baseUrl       String
  name          String?
  lastCrawledAt DateTime?
  crawlStatus   CrawlStatus @default(PENDING)
  crawlNote     String?
  createdAt     DateTime  @default(now())

  tenantCompanies     TenantCompany[]
  rawProfiles         RawCompanyProfile[]
  profile             CompanyProfile?
  personalizedContent PersonalizedContent?
}

model TenantCompany {
  tenantId      String
  companyId     String
  sourceBatchId String
  excluded      Boolean  @default(false)
  createdAt     DateTime @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  company     Company    @relation(fields: [companyId], references: [id])
  sourceBatch CrawlBatch @relation(fields: [sourceBatchId], references: [id])

  @@id([tenantId, companyId, sourceBatchId])
  @@index([tenantId])
  @@index([sourceBatchId])
}

model CrawlBatch {
  id                   String          @id @default(uuid())
  tenantId             String
  filePath             String?
  fileName             String?
  sourceType           BatchSourceType @default(UPLOAD)
  searchQuery          Json?
  discoveryKey         String?
  status               BatchStatus     @default(PENDING)
  totalCompanies       Int             @default(0)
  processedCompanies   Int             @default(0)
  completionPercentage Float           @default(0)
  exportPath           String?
  templateId           String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  template             EmailTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  tenantCompanies      TenantCompany[]
  discoveryCandidates  DiscoveryCandidate[]

  @@index([discoveryKey])
  @@index([sourceType, status, discoveryKey, updatedAt])
}

model RawCompanyProfile {
  id            String   @id @default(uuid())
  companyId     String
  baseUrl       String
  specificUrl   String
  normalizedUrl String
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, normalizedUrl])
}

model CompanyProfile {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  name                String?
  description         String?
  location            String?
  emails              Json     @default("[]")
  phones              Json     @default("[]")
  services            Json     @default("[]")
  representedBrands   Json     @default("[]")
  primaryIndustry     String?
  targetCustomers     String?
  team                Json     @default("[]")
  history             String?
  socialLinks         Json     @default("{}")
  completionScore     Float    @default(0)
  loginProtected      Boolean  @default(false)
  logoSourceUrl       String?
  companyNameFromLogo String?
  sloganFromLogo      String?
  logoNameConfidence  Int      @default(0)
  campaignEmail       String?
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model PersonalizedContent {
  id               String   @id @default(uuid())
  companyId        String   @unique
  emailSubject     String?
  openingLine      String?
  valueProposition String?
  fullMessage      String?
  generatedAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model DiscoveryCandidate {
  id               String          @id @default(uuid())
  batchId          String
  domain           String
  url              String
  title            String?
  snippet          String?
  status           CandidateStatus @default(KEPT)
  createdAt        DateTime        @default(now())

  // Hybrid discovery fields (added in discovery pipeline v2)
  pageType         String?   // PageType: TARGET_ORGANIZATION | MUNICIPALITY_PAGE | DIRECTORY_OR_PORTAL | …
  extractedFrom    String?   // URL of the parent page when this org was extracted from a list
  discoverySource  String?   // 'search' | 'registry' | 'municipality' | 'directory'
  confidence       Int?      // 0-100
  orgName          String?   // human-readable name (especially for orgs extracted from lists)
  extractedEmail   String?   // pre-crawl email discovered during page extraction
  extractedPhone   String?   // pre-crawl phone discovered during page extraction
  extractedAddress String?   // pre-crawl address discovered during page extraction
  rejectedReason   String?   // reason for FILTERED status (was only in-memory before)

  batch CrawlBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, domain])
}

enum CandidateStatus {
  KEPT
  FILTERED
  BLOCKED
  EXCLUDED
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BatchSourceType {
  UPLOAD
  PERSONA_SEARCH
}

enum UserRole {
  USER
  ADMIN
}

enum CrawlStatus {
  PENDING
  CRAWLING
  COMPLETED
  FAILED
  BLOCKED
}

model EmailTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  subject   String
  body      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches CrawlBatch[]
}

model SearchCache {
  id              String   @id @default(uuid())
  normalizedQuery String   @unique
  results         Json     @default("[]")
  providerUsed    String?
  lastSearchedAt  DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([lastSearchedAt])
}
