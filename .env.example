# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/companies_intelligence"

# Auth - JWT secret (must match NextAuth secret on FE)
JWT_SECRET="your-super-secret-jwt-key-here"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Storage
STORAGE_BASE_PATH="./storage"

# Worker concurrency
WORKER_CONCURRENCY=5

# Persona Search — Brave Search API (free tier: 1,000 queries/month)
# Get your key at: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=""

# Relevance filter — Groq API (free tier, llama-3.1-8b-instant)
# Get your key at: https://console.groq.com
# Optional: if unset, Brave results are returned without LLM filtering
GROQ_API_KEY=""

# Email (Brevo REST API — https://app.brevo.com)
#
# Development (BREVO_API_KEY blank):
#   - No emails are sent.
#   - Verification URL is printed to the API console.
#   - Register response includes `devVerificationUrl` so the frontend shows a clickable link.
#   - devVerificationUrl is NEVER returned when NODE_ENV=production.
#
# Production (BREVO_API_KEY set):
#   - Real emails are sent via the Brevo /v3/smtp/email endpoint (HTTPS, port 443).
#   - Create an API key at: Brevo → Settings → API Keys.
#   - EMAIL_FROM must match a verified sender in Brevo.
#
APP_URL="http://localhost:3001"
BREVO_API_KEY=
EMAIL_FROM="Companies Intelligence <noreply@yourapp.com>"
