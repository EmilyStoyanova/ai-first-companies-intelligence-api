{
  "name": "ai-first-companies-intelligence-api",
  "version": "1.0.0",
  "description": "B2B Data Enrichment Engine - API & Worker",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "concurrently --names \"api,worker\" --prefix-colors \"cyan,yellow\" \"ts-node-dev --respawn --transpile-only src/api/server.ts\" \"ts-node-dev --respawn --transpile-only src/worker/index.ts\"",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "start:worker": "node dist/worker/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "crawlee": "^3.11.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.4.1",
    "pg-boss": "^10.1.4",
    "playwright": "^1.49.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.10",
    "@types/papaparse": "^5.3.15",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
